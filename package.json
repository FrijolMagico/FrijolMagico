{
  "name": "frijolmagico",
  "version": "2.1.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:real": "DATA_SOURCE=real turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "type-check": "turbo run type-check",
    "db:migrate": "turbo run db:migrate --filter @frijolmagico/database",
    "db:rollback": "turbo run db:rollback --filter @frijolmagico/database",
    "db:status": "turbo run db:status --filter @frijolmagico/database",
    "db:new": "turbo run db:new --filter @frijolmagico/database",
    "db:seed": "turbo run db:seed --filter @frijolmagico/database",
    "format": "prettier --write \"**/*.{ts,tsx,md}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.8.1"
  },
  "packageManager": "bun@1.2.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
