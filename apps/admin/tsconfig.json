{
  "extends": "@frijolmagico/typescript-config/next",
  "compilerOptions": {
    "skipLibCheck": true,
    "types": [
      "bun"
    ],
    "paths": {
      "*": [
        "./*"
      ],
      "@/shared/": [
        "./src/shared/*"
      ],
      "@/core/*": [
        "./src/app/(core)/*"
      ],
      "@/auth/*": [
        "./src/app/(auth)/*"
      ],
      // Test folder
      "@/tests/*": [
        "./tests/*"
      ],
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules/*"
  ]
}
