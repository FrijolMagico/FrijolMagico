{
  "extends": "@frijolmagico/typescript-config/next",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/shared/*": [
        "./src/shared/*"
      ],
      // Sections (Add more as needed)
      "@/admin/*": [
        "./src/app/(authenticated)/(admin)/*"
      ],
      "@/dashboard/*": [
        "./src/app/(authenticated)/(dashboard)/*"
      ],
      "@/auth/*": [
        "./src/app/(auth)/*"
      ],
      // Globals
      "@/lib/*": [
        "./src/lib/*"
      ],
      "@/hooks/*": [
        "./src/hooks/*"
      ],
      "@/types/*": [
        "./src/types/*"
      ],
      "@/styles/*": [
        "./src/styles/*"
      ],
      // Fallback
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ]
}
