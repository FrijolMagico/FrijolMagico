{
  "extends": "@frijolmagico/typescript-config/next",
  "compilerOptions": {
    "skipLibCheck": true,
    "types": [
      "bun"
    ],
    "paths": {
      "@/shared/*": [
        "./src/shared/*"
      ],
      "@/core/*": [
        "./src/app/(core)/*"
      ],
      "@/auth/*": [
        "./src/app/(auth)/*"
      ],
      // Test folder
      "@/tests/*": [
        "./tests/*"
      ],
      "@/*": [
        "./src/*"
      ],
      "*": [
        "./*"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "../../packages/database/**/*.ts",
    "../../packages/utils/**/*.ts"
  ],
  "exclude": [
    "../web/"
  ]
}
