{
  "name": "@frijolmagico/database",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./types": "./src/types/index.ts"
  },
  "scripts": {
    "db:migrate": "bun run --env-file ../../.env.local geni up",
    "db:rollback": "bun run --env-file ../../.env.local geni down",
    "db:status": "bun run --env-file ../../.env.local geni status",
    "db:new": "bun run --env-file ../../.env.local geni new",
    "db:seed": "bun run --env-file ../../.env.local turso db shell $TURSO_DATABASE_NAME < seed/seed.sql",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@libsql/client": "^0.15.15",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@frijolmagico/typescript-config": "*",
    "typescript": "^5.9.3"
  }
}
