{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",

  "globalEnv": ["NODE_ENV", "VERCEL_ENV", "DATA_SOURCE"],
  "globalDependencies": [".env*"],

  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "TURSO_DATABASE_URL",
        "TURSO_AUTH_TOKEN",
        "GOOGLE_API_KEY",
        "CATALOG_SHEET_ID",
        "APPROVED_ARTISTS_SHEET_ID",
        "FESTIVAL_2025_SCHEDULE_SHEET_ID",
        "CDN_URL"
      ],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },

    "dev": {
      "cache": false,
      "persistent": true,
      "interactive": true
    },

    "lint": {
      "dependsOn": ["^build"],
      "outputs": []
    },

    "lint:fix": {
      "cache": false,
      "outputs": []
    },

    "type-check": {
      "dependsOn": ["^build"],
      "outputs": []
    },

    "db:migrate": {
      "cache": false,
      "env": ["TURSO_DATABASE_URL", "TURSO_AUTH_TOKEN"]
    },

    "db:rollback": {
      "cache": false,
      "env": ["TURSO_DATABASE_URL", "TURSO_AUTH_TOKEN"]
    },

    "db:status": {
      "cache": false,
      "env": ["TURSO_DATABASE_URL", "TURSO_AUTH_TOKEN"]
    },

    "db:seed": {
      "cache": false,
      "env": ["TURSO_DATABASE_URL", "TURSO_AUTH_TOKEN"]
    }
  }
}
